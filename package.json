{
  "name": "trident-vulnerability-package-scanner",
  "displayName": "Trident Vulnerability Package Scanner",
  "publisher": "TridentTeam",
  "version": "1.2.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "description": "",
  "main": "./out/extension.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p ./",
    "watch": "tsc -p ./ --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "security",
    "npm",
    "dependency",
    "vulnerability",
    "audit"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "activationEvents": [
    "onView:vulnerabilityView",
    "onCommand:vulnerability-scanner.scan",
    "onCommand:vulnerability-scanner.showLogs"
  ],
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "vulnerabilityView",
          "name": "Vulnerable Packages"
        }
      ]
    },
    "commands": [
      {
        "command": "vulnerability-scanner.scan",
        "title": "Vulnerability Package Scanner"
      },
      {
        "command": "vulnerability-scanner.showLogs",
        "title": "Show Audit Logs"
      },
      {
        "command": "vulnerabilityView.openWebview",
        "title": "Run Scanner"
      }
    ]
  },
  "dependencies": {
    "d3": "^7.9.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1"
  }
}
