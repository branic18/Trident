{
  "name": "trident-vulnerability-package-scanner",
  "displayName": "Trident Vulnerability Package Scanner",
  "publisher": "TridentTeam",
  "version": "1.3.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/branic18/Trident.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "description": "",
  "main": "./out/extension.js",
  "scripts": {
    "test": "npm run build && node tests/goose-ui-smoke.test.cjs && node tests/goose-ui-states.test.cjs && node tests/apply-code-fix.test.cjs && node tests/goose-cache.test.cjs && node tests/goose-sanitization.test.cjs && node tests/goose-concurrency.test.cjs && node tests/goose-webview-security.test.cjs",
    "build": "tsc -p ./",
    "watch": "tsc -p ./ --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "security",
    "npm",
    "dependency",
    "vulnerability",
    "audit"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "activationEvents": [
    "onView:vulnerabilityView",
    "onCommand:vulnerability-scanner.scan",
    "onCommand:vulnerability-scanner.showLogs",
    "onCommand:trident.openApiKeySettings",
    "onCommand:trident.addAiInsights"
  ],
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "vulnerabilityView",
          "name": "Vulnerable Packages"
        }
      ]
    },
    "configuration": {
      "title": "Trident Goose",
      "properties": {
        "trident.goose.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Goose AI analysis in the Inspector panel."
        },
        "trident.goose.recipePath": {
          "type": "string",
          "default": "./recipes/trident_vuln_explainer.yaml",
          "description": "Path to the Goose recipe to use."
        },
        "trident.goose.maxRetries": {
          "type": "number",
          "default": 1,
          "description": "Number of retries for Goose execution on transient failures."
        },
        "trident.goose.timeoutMs": {
          "type": "number",
          "default": 120000,
          "description": "Timeout in milliseconds for Goose execution."
        },
        "trident.goose.maxConcurrency": {
          "type": "number",
          "default": 2,
          "description": "Max concurrent Goose analyses."
        },
        "trident.goose.cacheMaxEntries": {
          "type": "number",
          "default": 200,
          "description": "Max cached Goose analyses before LRU eviction."
        },
        "trident.goose.cacheMaxAgeMs": {
          "type": "number",
          "default": 604800000,
          "description": "Cache TTL in milliseconds for Goose analyses."
        },
        "trident.goose.dataMode": {
          "type": "string",
          "enum": [
            "full",
            "metadata"
          ],
          "default": "full",
          "description": "Data sent to Goose: full (includes snippets) or metadata-only."
        },
        "trident.goose.sharedCacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace-shared Goose cache under .trident/ (opt-in)."
        },
        "trident.goose.provider": {
          "type": "string",
          "default": "openrouter",
          "description": "AI provider for Goose (e.g. openrouter, openai, anthropic)."
        },
        "trident.goose.model": {
          "type": "string",
          "default": "openai/gpt-5.1",
          "description": "Model ID for Goose (e.g. openai/gpt-5.1 for OpenRouter)."
        }
      }
    },
    "commands": [
      {
        "command": "vulnerability-scanner.scan",
        "title": "Vulnerability Package Scanner"
      },
      {
        "command": "vulnerability-scanner.showLogs",
        "title": "Show Audit Logs"
      },
      {
        "command": "vulnerabilityView.openWebview",
        "title": "Run Scanner"
      },
      {
        "command": "trident.openApiKeySettings",
        "title": "API Key Settings"
      },
      {
        "command": "trident.addAiInsights",
        "title": "Trident | Add AI Insights"
      }
    ]
  },
  "dependencies": {
    "d3": "^7.9.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1"
  }
}